  { "text": "Die Ärztin untersucht den Patienten.", "type": "sentence", "difficulty": "hard" },
  { "text": "Wir feiern morgen Geburtstag.", "type": "sentence", "difficulty": "hard" },
  { "text": "Das Mädchen schreibt einen Brief.", "type": "sentence", "difficulty": "hard" },
  { "text": "Der kleine Hund rennt im Garten.", "type": "sentence", "difficulty": "hard" },
  { "text": "Meine Schwester geht in die Schule.", "type": "sentence", "difficulty": "hard" },
  { "text": "Die Blumen blühen im Frühling.", "type": "sentence", "difficulty": "hard" },
  { "text": "Am Abend lesen wir eine Geschichte.", "type": "sentence", "difficulty": "hard" },
  { "text": "Wir haben gestern Fußball gespielt.", "type": "sentence", "difficulty": "hard" },
  { "text": "Die Lehrerin erklärt die Aufgabe.", "type": "sentence", "difficulty": "hard" },
  { "text": "Der Junge trägt seinen Rucksack.", "type": "sentence", "difficulty": "hard" },
  { "text": "Das Kätzchen schläft auf dem Sofa.", "type": "sentence", "difficulty": "hard" },
  { "text": "Mein Bruder liest ein dickes Buch.", "type": "sentence", "difficulty": "hard" },
  { "text": "Der Arzt hilft dem kranken Kind.", "type": "sentence", "difficulty": "hard" },
  { "text": "Die Schüler singen ein Lied.", "type": "sentence", "difficulty": "hard" },
  { "text": "Das Eichhörnchen klettert auf den Baum.", "type": "sentence", "difficulty": "hard" },
  { "text": "Wir besuchen die Großeltern am Sonntag.", "type": "sentence", "difficulty": "hard" },
  { "text": "Der Bäcker backt frisches Brot.", "type": "sentence", "difficulty": "hard" },
  { "text": "Die Kinder spielen auf dem Schulhof.", "type": "sentence", "difficulty": "hard" },
  { "text": "Meine Mutter kauft Äpfel und Birnen.", "type": "sentence", "difficulty": "hard" },
  { "text": "Der Zug fährt pünktlich ab.", "type": "sentence", "difficulty": "hard" },
  { "text": "Das Mädchen malt ein schönes Bild.", "type": "sentence", "difficulty": "hard" },
  { "text": "Im Sommer fahren wir ans Meer.", "type": "sentence", "difficulty": "hard" },
  { "text": "Die Katze jagt die graue Maus.", "type": "sentence", "difficulty": "hard" },
  { "text": "Heute ist das Wetter sehr schön.", "type": "sentence", "difficulty": "hard" },
  { "text": "Der Schüler vergisst seine Hausaufgaben.", "type": "sentence", "difficulty": "hard" },
  { "text": "Wir essen Würstchen mit Senf.", "type": "sentence", "difficulty": "hard" },
  { "text": "Die Köchin bereitet das Mittagessen vor.", "type": "sentence", "difficulty": "hard" },
